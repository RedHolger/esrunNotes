# Next.js Configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Auth0 Configuration
AUTH0_SECRET=your-auth0-secret-here
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Google AI Configuration
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Mistral AI Configuration
MISTRAL_API_KEY=your-mistral-api-key

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# AssemblyAI Configuration
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Twilio Configuration (Paid)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
TWILIO_WHATSAPP_NUMBER=+14155238886

# Free SMS Configuration (TextBelt - 1 free SMS per day)
SMS_PROVIDER=textbelt
SMS_API_KEY=textbelt

# Free WhatsApp Configuration (Maytapi - 100 free messages/month)
WHATSAPP_PROVIDER=maytapi
MAYTAPI_API_KEY=your-maytapi-api-key
MAYTAPI_PHONE_ID=your-maytapi-phone-id

# Email Configuration (Mailgun only)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.mailgun.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
EMAIL_PASS=your-app-password
EMAIL_FROM=NurseNotes <noreply@nursenotes.com>

# PostgreSQL Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/nursenotes

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
